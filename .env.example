# =============================================================================
# Copy to `.env` and edit. `.env` is gitignored — never commit it.
# =============================================================================

# ---- Compose -----------------------------------------------------------------
# All container names + networks + volumes are prefixed with this so multiple
# instances (staging / prod) on the same host don't collide.
COMPOSE_PROJECT_PREFIX=gfn

# Set to your Hetzner timezone if different.
TZ=Europe/Bucharest

# ---- PostgreSQL --------------------------------------------------------------
POSTGRES_DB=grafana_new
POSTGRES_USER=grafana_new_user
# CHANGE THIS — must be strong; lowercase letters + digits + symbols.
POSTGRES_PASSWORD=change-me-postgres-password
# Loopback-only host port for ad-hoc psql access via SSH tunnel.
POSTGRES_HOST_PORT=55432

# ---- API ---------------------------------------------------------------------
API_PORT=4100
# 0.0.0.0 = bind everywhere (Alertmanager on another host needs this).
# 127.0.0.1 = loopback only (when API + Alertmanager + Grafana share the host
# AND the same Docker network — recommended).
API_HOST_BIND=0.0.0.0

# Connection-pool size. Bigger numbers = more concurrent SSE clients without
# starving real queries. Each pool slot = one open Postgres connection.
DB_POOL_MIN=4
DB_POOL_MAX=40

# Public Grafana domain used by users in browser.
# Change this when moving to a new domain.
PUBLIC_DOMAIN=ia.aurora.direct

# Comma-separated list of origins allowed to call the API.
CORS_ORIGIN=https://ia.aurora.direct

# ---- Alertmanager → API webhook auth -----------------------------------------
# Long random string used to authenticate the Alertmanager webhook against the
# API. Generate one with: `openssl rand -hex 32`. The SAME value must appear
# in `monitoring/alertmanager/alertmanager.yml` under `credentials:` (or in
# the receiver block you paste into your existing Alertmanager).
ALERTMANAGER_WEBHOOK_TOKEN=change-me-with-openssl-rand-hex-32

# Default labels Alertmanager attaches to firing alerts. Adjust only if your
# rules / exporters use different label names than what alert_rules.yml expects.
ALERTMANAGER_STORE_LABELS=store_code,store
ALERTMANAGER_DEVICE_LABELS=device_name,device,instance
ALERTMANAGER_DEVICE_TYPE_LABELS=device_type,type
ALERTMANAGER_DEFAULT_DEVICE_TYPE=generic

# ---- Alertmanager -------------------------------------------------------------
# Alertmanager is started by default by docker compose.
# Pick a port that's NOT already taken by another Alertmanager on the host.
ALERTMANAGER_HOST_PORT=9093